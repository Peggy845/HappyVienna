<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light_grey">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 置頂任務防禦條  -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_top_mission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/theme_status_blue"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <TextView
                android:id="@+id/tv_top_mission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="ℹ️ 爸爸禁食中 (剩餘 6 小時)\n明天 08:00 抽血"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <!-- 快捷指令區 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="每日必備"
            android:textColor="@color/text_primary_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_quick_nfc"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="💊 嗶藥"
                android:textSize="24sp"
                app:backgroundTint="@color/theme_aot_green"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_quick_bp"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:text="🩸 血壓"
                android:textSize="24sp"
                app:backgroundTint="@color/theme_primary_dark_blue"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- 資訊流卡片預留區 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日動態"
            android:textColor="@color/text_primary_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp"/>

        <!-- 這裡未來會替換成 RecyclerView 來動態載入資訊 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日行程"
            android:textColor="@color/text_primary_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日動態 (目標清單)"
            android:textColor="@color/text_primary_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/layout_daily_goals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="8dp">
        </LinearLayout>
    </LinearLayout>

</ScrollView>
